# ============================================================
# ENVIRONMENT VARIABLES — Job Portal Django (EXAMPLE TEMPLATE)
# ============================================================
# Copy this file to .env and fill in the real values.
#   cp .env.example .env
# ============================================================


# ----------------------------------------------------------
# Django Core
# ----------------------------------------------------------
SECRET_KEY=your-secret-key-here

# Set to False in production!
DEBUG=True

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=127.0.0.1,localhost


# ----------------------------------------------------------
# Database
# ----------------------------------------------------------
# SQLite (local development)
DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (production)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME


# ----------------------------------------------------------
# Cache / Redis (optional)
# ----------------------------------------------------------
# REDIS_URL=redis://127.0.0.1:6379/0


# ----------------------------------------------------------
# Email (optional)
# ----------------------------------------------------------
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=


# ----------------------------------------------------------
# Static / Media (production only)
# ----------------------------------------------------------
# STATIC_ROOT=/var/www/jobportal/staticfiles
# MEDIA_ROOT=/var/www/jobportal/media
